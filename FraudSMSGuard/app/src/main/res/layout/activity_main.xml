<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛡️ SMS Fraud Guard"
                android:textSize="22sp"
                android:textColor="#F1F5F9"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="⚙️"
                android:textSize="18sp"
                android:background="@android:color/transparent"
                android:minWidth="48dp" />
        </LinearLayout>

        <!-- Status Bar -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏸️ Inactive"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="20dp" />

        <!-- Stats Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:weightSum="3">

            <!-- Total Scanned -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/totalScanned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textColor="#3B82F6"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanned"
                    android:textSize="11sp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- Fraud Detected -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp">

                <TextView
                    android:id="@+id/fraudDetected"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textColor="#EF4444"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fraud"
                    android:textSize="11sp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- Blocked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/blockedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textColor="#F59E0B"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blocked"
                    android:textSize="11sp"
                    android:textColor="#64748B" />
            </LinearLayout>
        </LinearLayout>

        <!-- Monitoring Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📡 SMS Monitoring"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/monitorSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#10B981"
                android:trackTint="#374151" />
        </LinearLayout>

        <!-- Auto-Block Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚫 Auto-Block Fraud"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/autoBlockSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#EF4444"
                android:trackTint="#374151" />
        </LinearLayout>

        <!-- Test SMS Scanner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Test SMS Scanner"
            android:textColor="#F1F5F9"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/testInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste an SMS message to test..."
            android:textColor="#F1F5F9"
            android:textColorHint="#64748B"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:textSize="14sp"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="12dp"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/testButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔍 Scan Message"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/testResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone" />

        <!-- View Blocked Messages -->
        <Button
            android:id="@+id/blockedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🚫 View Blocked Messages"
            android:textColor="#F1F5F9"
            android:textSize="14sp"
            android:background="@drawable/button_outline"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
